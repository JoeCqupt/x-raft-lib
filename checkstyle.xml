<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Conservative Checkstyle rules for x-raft-lib. Complements Spotless
    (which handles unused imports and trailing whitespace) with structural
    checks that Spotless doesn't cover.

    NOT included (to avoid churn): Javadoc rules, naming conventions
    (the codebase follows etcd-raft naming), line length, indentation.
-->
<module name="Checker">
    <property name="severity" value="error"/>

    <!-- Exclude generated protobuf sources. -->
    <module name="BeforeExecutionExclusionFileFilter">
        <property name="fileNamePattern" value=".*[\\/]proto[\\/].*\.java$"/>
    </module>

    <module name="TreeWalker">
        <!-- Imports -->
        <module name="AvoidStarImport">
            <!-- Allow star imports for the project's own packages (ported
                 from Go, used consistently throughout the codebase). -->
            <property name="excludes"
                      value="io.github.xinfra.lab.raft,io.github.xinfra.lab.raft.internal,io.github.xinfra.lab.raft.internal.confchange,io.github.xinfra.lab.raft.internal.quorum,io.github.xinfra.lab.raft.internal.tracker"/>
        </module>
        <module name="IllegalImport">
            <property name="illegalPkgs" value="sun"/>
        </module>

        <!-- Block checks -->
        <module name="EmptyBlock">
            <property name="option" value="text"/>
        </module>

        <!-- Coding -->
        <module name="FallThrough"/>
        <module name="UpperEll"/>
        <module name="ArrayTypeStyle"/>

        <!-- Modifiers -->
        <module name="RedundantModifier"/>
    </module>
</module>
