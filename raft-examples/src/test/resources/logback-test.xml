<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- %X{...} surfaces the raft MDC context set by DefaultNode (see RaftMdc). -->
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{16} [node=%X{raftNodeId} term=%X{raftTerm} %X{raftState} lead=%X{raftLeader}] - %msg%n</pattern>
        </encoder>
    </appender>
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
    <logger name="io.grpc" level="WARN"/>
    <logger name="io.grpc.netty" level="WARN"/>
</configuration>
